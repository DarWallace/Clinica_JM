# docker-compose.override.yml.example
# Copia este archivo como docker-compose.override.yml para personalizar tu configuración

services:
    laravel.test:
        ports:
            # Cambiar el puerto si tienes conflictos
            - '8000:80'  # En lugar de '80:80'
            # Habilitar xdebug si lo necesitas
        environment:
            # Configuración de Xdebug para desarrollo
            SAIL_XDEBUG_MODE: "develop,debug"
            SAIL_XDEBUG_CONFIG: "client_host=host.docker.internal"
        # Volúmenes adicionales si los necesitas
        # volumes:
        #     - './custom-config:/etc/custom'

    mysql:
        ports:
            # Cambiar el puerto de MySQL si tienes conflictos
            - '3307:3306'  # En lugar de '3306:3306'
        # Configuración adicional de MySQL
        # environment:
        #     MYSQL_ROOT_PASSWORD: 'custom_password'

    # Añadir Redis si lo necesitas
    # redis:
    #     image: 'redis:alpine'
    #     ports:
    #         - '${FORWARD_REDIS_PORT:-6379}:6379'
    #     networks:
    #         - sail

